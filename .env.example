# ============================================
# URBANIKA - ENVIRONMENT VARIABLES
# ============================================
# Copia este archivo a .env y llena los valores

# ============================================
# BLOCKCHAIN - SCROLL NETWORK
# ============================================

# Private key de tu wallet (SIN el prefijo 0x)
# ⚠️ NUNCA compartas esta key ni la subas a Git
# Puedes exportarla desde MetaMask: Settings > Advanced > Export Private Key
PRIVATE_KEY=your_private_key_here

# RPC URLs (Opcional - ya hay defaults en hardhat.config.ts)
SCROLL_SEPOLIA_RPC_URL=https://sepolia-rpc.scroll.io/
SCROLL_RPC_URL=https://rpc.scroll.io/
SEPOLIA_RPC_URL=https://rpc2.sepolia.org

# Scrollscan API Key (Opcional - para verificar contratos)
# Obtenerla en: https://scrollscan.com/myapikey
SCROLLSCAN_API_KEY=your_scrollscan_api_key

# Etherscan API Key (Para Sepolia testnet)
ETHERSCAN_API_KEY=your_etherscan_api_key

# ============================================
# SMART CONTRACT DEPLOYED
# ============================================

# Dirección del contrato UrbanikaNFT desplegado
# Se llena después de hacer el deployment
URBANIKA_NFT_ADDRESS=

# Network donde está desplegado (scrollSepolia, scroll)
DEPLOYED_NETWORK=scrollSepolia

# ============================================
# IPFS / STORAGE
# ============================================

# Pinata (para subir metadata e imágenes a IPFS)
# Obtener en: https://pinata.cloud
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_API_KEY=your_pinata_secret

# NFT.Storage (alternativa gratuita)
# Obtener en: https://nft.storage
NFT_STORAGE_API_KEY=your_nft_storage_key

# ============================================
# PAYMENT PROVIDERS
# ============================================

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Coinbase Commerce (para pagos crypto)
COINBASE_COMMERCE_API_KEY=your_coinbase_commerce_key

# ============================================
# DATABASE / BACKEND
# ============================================

# URL de tu base de datos (MongoDB, PostgreSQL, etc.)
DATABASE_URL=your_database_url

# NextAuth (si usas autenticación)
NEXTAUTH_SECRET=your_nextauth_secret
NEXTAUTH_URL=http://localhost:3000

# ============================================
# OTROS
# ============================================

# Gas reporter
REPORT_GAS=false
COINMARKETCAP_API_KEY=your_coinmarketcap_key

# Environment (development, production)
NODE_ENV=development

# ============================================
# FAUCETS Y RECURSOS (TESTNET)
# ============================================
#
# Para obtener ETH en Scroll Sepolia:
# 1. Obtén Sepolia ETH: https://sepoliafaucet.com/
# 2. Bridge a Scroll Sepolia: https://sepolia.scroll.io/bridge
#
# Exploradores:
# - Scroll Sepolia: https://sepolia.scrollscan.com/
# - Scroll Mainnet: https://scrollscan.com/
# ============================================
